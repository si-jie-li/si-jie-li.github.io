{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Jekyll Dev Server",
      "runtimeExecutable": "bundle",
      "runtimeArgs": ["exec", "jekyll", "serve", "--livereload"],
      "port": 4000
    },
    {
      "name": "JS Watcher (npm watch:js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "watch:js"],
      "port": null
    }
  ]
}
